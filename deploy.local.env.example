# Copy to deploy.local.env and fill in values:
#   cp deploy/deploy.local.env.example deploy/deploy.local.env

DEPLOY_HOST=212.23.201.113
DEPLOY_PORT=15726
DEPLOY_USER=root
DEPLOY_PASSWORD=

REMOTE_BACKEND_PATH=/var/www/daizima-backend
REMOTE_FRONTEND_PATH=/var/www/daizima-frontend

# Used when building frontend locally (on Windows/Git Bash use deploy-from-local.sh — it sets MSYS_NO_PATHCONV)
NUXT_PUBLIC_API_BASE_URL=/api
NUXT_API_PROXY_TARGET=http://127.0.0.1:8100
NUXT_PUBLIC_SITE_URL=https://daizima.com
NUXT_PUBLIC_WEBSOCKET_URL=wss://daizima.com/ws
NUXT_PUBLIC_APP_NAME=Daizima
NUXT_PUBLIC_APP_ENV=production

# Optional: Cloudflare API token (Zone → DNS Edit) for ./deploy/ssl-issue-letsencrypt.sh
# CLOUDFLARE_API_TOKEN=
